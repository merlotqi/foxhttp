# Default: normalize line endings on checkout/commit
* text=auto

# Sources & project text
*.c   text diff=cpp
*.cc  text diff=cpp
*.cpp text diff=cpp
*.cxx text diff=cpp
*.h   text diff=cpp
*.hh  text diff=cpp
*.hpp text diff=cpp
*.hxx text diff=cpp
*.inl text diff=cpp
*.ipp text diff=cpp

*.cmake text
*.cmake.in text
CMakeLists.txt text

*.md    text diff=markdown
*.txt   text
*.in    text
*.yml   text
*.yaml  text
Dockerfile text
.gitignore text
.gitattributes text

# Shell / scripts
*.sh text eol=lf

# Binary assets & libs
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.a binary
*.lib binary
*.dll binary
*.so binary
*.dylib binary
*.exe binary

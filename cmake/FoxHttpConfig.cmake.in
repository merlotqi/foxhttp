# FoxHttp CMake package — dependency search matches how this library was built.
#
# Pkg-config: this install also provides lib/pkgconfig/foxhttp.pc. When not using
# CMake targets, compile/link with:
#   pkg-config --cflags --libs foxhttp
# For static archives (libfoxhttplib.a), also pass private deps:
#   pkg-config --static --cflags --libs foxhttp
# nlohmann_json is header-only and is not listed in foxhttp.pc Requires; keep the
# same include layout as when using target FoxHttp::foxhttplib.

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Boost REQUIRED COMPONENTS system json iostreams)
find_dependency(ZLIB REQUIRED)
find_dependency(spdlog REQUIRED)
find_dependency(nlohmann_json CONFIG REQUIRED)
find_dependency(yaml-cpp CONFIG REQUIRED)

if(@FOXHTTP_CONFIG_ENABLE_TLS@)
    find_dependency(OpenSSL REQUIRED)
endif()

if(@FOXHTTP_CONFIG_BUILD_WITH_BROTLI@)
    if(@FOXHTTP_CONFIG_USE_VCPKG_BROTLI@)
        find_dependency(unofficial-brotli CONFIG REQUIRED)
    else()
        find_dependency(Brotli REQUIRED)
    endif()
endif()

if(@FOXHTTP_CONFIG_ENABLE_JWT@)
    find_dependency(jwt-cpp CONFIG REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/FoxHttpTargets.cmake")
